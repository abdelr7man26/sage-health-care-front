# ─── SAGE Healthcare — Frontend Environment Variables ──────────────────────────
# Copy this file to .env.production (for production) or .env.development (for dev).
# Vite reads the appropriate file based on the build mode.
# NEVER commit .env.production with real values to version control.

# [REQUIRED] Full base URL of the backend API (no trailing slash)
# Development:  http://localhost:5000/api
# Production:   https://yourdomain.com/api
VITE_API_URL=https://yourdomain.com/api
